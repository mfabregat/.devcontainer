{
    "name": "${localWorkspaceFolderBasename}",
    "remoteUser": "marc",
    "dockerComposeFile": "./docker-compose.yaml",
    "service": "devcontainer_service",
    "workspaceFolder": "${localWorkspaceFolder}",
    "initializeCommand": "bash .devcontainer/initialize.sh",
    "containerEnv": {
        "USER": "$remoteUser"
    },
    "remoteEnv": {
        "SSH_AUTH_SOCK": "${localEnv:SSH_AUTH_SOCK}"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            },
            "extensions": [
                "ms-azuretools.vscode-docker",
                "DavidAnson.vscode-markdownlint",
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "mhutchie.git-graph"
            ]
        }
    },
    // OpenCode server will be started in the background after the container starts
    "postStartCommand": "nohup bash -c 'opencode serve --hostname 0.0.0.0 --port 4096 &' > /tmp/opencode_start.log 2>&1"
    // Open with opencode attach http://localhost:4096
}