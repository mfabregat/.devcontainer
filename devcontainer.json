{
    "name": "${localWorkspaceFolderBasename}",
    "remoteUser": "${localEnv:USER}",
    "dockerComposeFile": "./docker-compose.yaml",
    "service": "devcontainer_service",
    "workspaceFolder": "${localWorkspaceFolder}",
    "initializeCommand": "bash .devcontainer/initialize.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "DavidAnson.vscode-markdownlint",
                "ms-python.python",
                "ms-vscode.cpptools",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "mhutchie.git-graph"
            ]
        }
    },
    // OpenCode
    "mounts": [
        "source=${localEnv:HOME}/.config/opencode,target=${localEnv:HOME}/.config/opencode,type=bind,consistency=cached", // config
        "source=${localEnv:HOME}/.local/share/opencode,target=${localEnv:HOME}/.local/share/opencode,type=bind,consistency=cached" // API keys
    ],
    "postStartCommand": "nohup bash -c 'sudo chown -R $(id -u):$(id -g) ~/.local && opencode serve --hostname 0.0.0.0 --port 4096 &' > /tmp/opencode_start.log 2>&1"
    // Open in host with: opencode attach http://localhost:4096
}